{
  "datasets": [
    {
      "name": "labor_pct_30d",
      "displayName": "Labor % of sales, last 30 days",
      "queryLines": [
        "SELECT s.date,",
        "       ROUND(SUM(l.labor_cost) / NULLIF(SUM(s.revenue), 0) * 100, 1) AS labor_pct_of_sales",
        "FROM identifier(:catalog || '.' || :schema || '.facts_sales_daypart') s",
        "JOIN identifier(:catalog || '.' || :schema || '.facts_labor_daypart') l",
        "  ON s.date = l.date AND s.store_id = l.store_id AND s.daypart = l.daypart",
        "WHERE s.date >= current_date() - INTERVAL 30 DAYS",
        "GROUP BY s.date",
        "ORDER BY s.date"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "sales_by_daypart_today",
      "displayName": "Sales by daypart, today vs forecast",
      "queryLines": [
        "SELECT daypart,",
        "       SUM(revenue) AS revenue,",
        "       SUM(forecast_revenue) AS forecast",
        "FROM identifier(:catalog || '.' || :schema || '.facts_sales_daypart')",
        "WHERE date = current_date()",
        "GROUP BY daypart",
        "ORDER BY MIN(hour_start)"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "stock_health",
      "displayName": "Stock health: SKUs below reorder point",
      "queryLines": [
        "WITH latest AS (",
        "  SELECT * FROM identifier(:catalog || '.' || :schema || '.facts_sales_inventory_daily')",
        "  WHERE date = (SELECT MAX(date) FROM identifier(:catalog || '.' || :schema || '.facts_sales_inventory_daily'))",
        ")",
        "SELECT i.category,",
        "       COUNT(*) AS sku_count,",
        "       SUM(CASE WHEN l.on_hand_eod < l.reorder_point THEN 1 ELSE 0 END) AS below_par",
        "FROM latest l",
        "JOIN identifier(:catalog || '.' || :schema || '.dims_items') i USING (sku)",
        "GROUP BY i.category",
        "ORDER BY i.category"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "sentiment_30d",
      "displayName": "Sentiment timeline, last 30 days",
      "queryLines": [
        "SELECT date,",
        "       SUM(CASE WHEN sentiment_label = 'pos' THEN 1 ELSE 0 END) AS pos,",
        "       SUM(CASE WHEN sentiment_label = 'neu' THEN 1 ELSE 0 END) AS neu,",
        "       SUM(CASE WHEN sentiment_label = 'neg' THEN 1 ELSE 0 END) AS neg",
        "FROM identifier(:catalog || '.' || :schema || '.facts_customer_feedback')",
        "WHERE date >= current_date() - INTERVAL 30 DAYS",
        "GROUP BY date",
        "ORDER BY date"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    }
  ],
  "pages": [
    {
      "name": "main",
      "displayName": "Operator Insights",
      "layout": []
    }
  ]
}
